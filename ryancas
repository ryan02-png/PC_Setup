# --- HELPER FUNCTION 1: WINGET INSTALLER ---
function script:Install-App {
    param($appName, $wingetId)
    $result = [System.Windows.Forms.MessageBox]::Show("Install $appName?", "Confirmation", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Question)
    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
        Write-Host "Starting installation for $appName..." -ForegroundColor Cyan
        $cmd = "winget install --id $wingetId --silent --accept-package-agreements --accept-source-agreements"
        Invoke-Expression $cmd
        [System.Windows.Forms.MessageBox]::Show("$appName installation process finished.")
    }
}

# --- HELPER FUNCTION 2: GITHUB CUSTOM INSTALLER ---
function script:Install-CustomApp {
    param($appName, $fileName, $isMsi, $installArgs)
    $result = [System.Windows.Forms.MessageBox]::Show("Install $appName?", "Confirmation", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Question)
    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
        Write-Host "Downloading $appName from GitHub..." -ForegroundColor Cyan
        
        $directUrl = "https://github.com/ryan02-png/PC_Setup/raw/refs/heads/main/$fileName"
        $tempFile = "$env:TEMP\$fileName"
        
        try {
            Invoke-WebRequest -Uri $directUrl -OutFile $tempFile -UseBasicParsing
            
            if ((Get-Item $tempFile).Length -lt 100KB) {
                [System.Windows.Forms.MessageBox]::Show("Download failed. Make sure you uploaded '$fileName' to your GitHub repo!")
                return
            }

            Write-Host "Installing $appName silently..." -ForegroundColor Cyan
            
            if ($isMsi) {
                $msiArgs = @("/i", "`"$tempFile`"") + $installArgs
                Start-Process -FilePath "msiexec.exe" -ArgumentList $msiArgs -Wait -NoNewWindow
            } else {
                Start-Process -FilePath $tempFile -ArgumentList $installArgs -Wait -NoNewWindow
            }
            
            Remove-Item -Path $tempFile -Force
            [System.Windows.Forms.MessageBox]::Show("$appName installation finished.")
        } catch {
            [System.Windows.Forms.MessageBox]::Show("Error downloading or installing $appName. Check the file link.")
        }
    }
}

