# --- HELPER FUNCTION 1: WINGET INSTALLER ---
function script:Install-App {
    param($appName, $wingetId)
    $result = [System.Windows.Forms.MessageBox]::Show("Install $appName?", "Confirmation", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Question)
    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
        Write-Host "Starting installation for $appName..." -ForegroundColor Cyan
        $cmd = "winget install --id $wingetId --silent --accept-package-agreements --accept-source-agreements"
        Invoke-Expression $cmd
        [System.Windows.Forms.MessageBox]::Show("$appName installation process finished.")
    }
}

# --- HELPER FUNCTION 2: GITHUB CUSTOM INSTALLER ---
function script:Install-CustomApp {
    param($appName, $fileName, $isMsi, $installArgs)
    $result = [System.Windows.Forms.MessageBox]::Show("Install $appName?", "Confirmation", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Question)
    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
        Write-Host "Downloading $appName from GitHub..." -ForegroundColor Cyan
        
        $directUrl = "https://github.com/ryan02-png/PC_Setup/raw/refs/heads/main/$fileName"
        $tempFile = "$env:TEMP\$fileName"
        
        try {
            Invoke-WebRequest -Uri $directUrl -OutFile $tempFile -UseBasicParsing
            
            if ((Get-Item $tempFile).Length -lt 100KB) {
                [System.Windows.Forms.MessageBox]::Show("Download failed. Make sure you uploaded '$fileName' to your GitHub repo!")
                return
            }

            Write-Host "Installing $appName silently..." -ForegroundColor Cyan
            
            if ($isMsi) {
                $msiArgs = @("/i", "`"$tempFile`"") + $installArgs
                Start-Process -FilePath "msiexec.exe" -ArgumentList $msiArgs -Wait -NoNewWindow
            } else {
                Start-Process -FilePath $tempFile -ArgumentList $installArgs -Wait -NoNewWindow
            }
            
            Remove-Item -Path $tempFile -Force
            [System.Windows.Forms.MessageBox]::Show("$appName installation finished.")
        } catch {
            [System.Windows.Forms.MessageBox]::Show("Error downloading or installing $appName. Check the file link.")
        }
    }
}

# --- HELPER FUNCTION 3: MENU BUTTON STYLER ---
function script:Create-MenuButton ($text, $yPos, $action) {
    $btn = New-Object System.Windows.Forms.Button
    $btn.Text = $text
    $btn.Location = "50,$yPos"
    $btn.Size = "330,45"
    # This anchor makes the button stretch horizontally when resizing the window
    $btn.Anchor = [System.Windows.Forms.AnchorStyles]::Top -bor [System.Windows.Forms.AnchorStyles]::Left -bor [System.Windows.Forms.AnchorStyles]::Right
    $btn.FlatStyle = "Flat"
    $btn.BackColor = $script:btnGray
    $btn.ForeColor = $script:textWhite
    $btn.FlatAppearance.BorderColor = $script:borderGray
    $btn.Add_Click($action)
    return $btn
}

# --- FUNCTION 1: MAIN MENU ---
function script:Show-Main-Menu {
    $script:form.Controls.Clear()
    
    $lbl = New-Object System.Windows.Forms.Label
    $lbl.Text = "Ryan Standardization"
    $lbl.Font = New-Object System.Drawing.Font("Segoe UI", 14, [System.Drawing.FontStyle]::Bold)
    $lbl.Location = "0,25"
    $lbl.Size = "450,40"
    $lbl.TextAlign = "MiddleCenter"
    $lbl.Anchor = [System.Windows.Forms.AnchorStyles]::Top -bor [System.Windows.Forms.AnchorStyles]::Left -bor [System.Windows.Forms.AnchorStyles]::Right

    $btn1 = script:Create-MenuButton "👤 Local Admin User Setup" 80 { Start-Process "lusrmgr.msc" }
    $btn2 = script:Create-MenuButton "⚙️ GP Edit Setup" 140 { script:Show-GPO-Menu }
    $btn3 = script:Create-MenuButton "📦 Install Apps" 200 { script:Show-Install-Apps }
    $btn4 = script:Create-MenuButton "🎛️ Control Panel" 260 { Start-Process "control" }
    
    $btn5 = script:Create-MenuButton "🛠️ System Repair (SFC / DISM)" 320 { 
        $msg = [System.Windows.Forms.MessageBox]::Show("Open new window to repair Windows? (Takes 15 mins)", "System Repair", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Warning)
        if ($msg -eq [System.Windows.Forms.DialogResult]::OK) {
            $repairCmd = "-NoExit -Command `"Write-Host 'Running DISM...' -ForegroundColor Cyan; DISM /Online /Cleanup-Image /RestoreHealth; Write-Host '`nRunning SFC...' -ForegroundColor Cyan; sfc /scannow; Write-Host '`nRepair Complete!' -ForegroundColor Green`""
            Start-Process powershell.exe -ArgumentList $repairCmd
        }
    }

    $btn6 = script:Create-MenuButton "🧹 Storage & Browser Cleanup" 380 { 
        $msg = [System.Windows.Forms.MessageBox]::Show("Force-close browsers, wipe Temp files, Cache, History, and Windows Update cache?", "Storage Cleanup", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Warning)
        if ($msg -eq [System.Windows.Forms.DialogResult]::OK) {
            Write-Host "Cleaning up system..." -ForegroundColor Yellow
            $oldAction = $ErrorActionPreference; $ErrorActionPreference = 'SilentlyContinue'

            Stop-Process -Name chrome, msedge, firefox, brave -Force

            Get-ChildItem -Path $env:TEMP -Recurse -Force | Remove-Item -Recurse -Force
            Get-ChildItem -Path "$env:WINDIR\Temp" -Recurse -Force | Remove-Item -Recurse -Force
            Get-ChildItem -Path "$env:WINDIR\Prefetch" -Recurse -Force | Remove-Item -Recurse -Force

            Stop-Service -Name wuauserv -Force
            Get-ChildItem -Path "$env:WINDIR\SoftwareDistribution\Download" -Recurse -Force | Remove-Item -Recurse -Force
            Start-Service -Name wuauserv

            $paths = @("$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Cache\Cache_Data\*", "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\History", "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\Cache\Cache_Data\*", "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\History", "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\Default\Cache\Cache_Data\*", "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\Default\History", "$env:LOCALAPPDATA\Mozilla\Firefox\Profiles\*\cache2\*")
            foreach ($p in $paths) { Remove-Item -Path $p -Recurse -Force }
            
            $ErrorActionPreference = $oldAction
            [System.Windows.Forms.MessageBox]::Show("Cleanup complete!")
        }
    }
    
    $script:form.Controls.AddRange(@($lbl, $btn1, $btn2, $btn3, $btn4, $btn5, $btn6))
}

