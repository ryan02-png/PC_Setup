                    Remove-AppxPackage -Package $pkg.PackageFullName -User $script:wmiUser -ErrorAction SilentlyContinue
                }
            }
            [System.Windows.Forms.MessageBox]::Show("Snipping Tool, Solitaire, and Outlook completely removed for this user.")
        }
    }

    $script:form.Controls.AddRange(@($btnBack, $panel))
