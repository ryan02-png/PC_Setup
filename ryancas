# Ensure secure connection to GitHub
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# 1. Admin Check
if (-NOT ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    [System.Windows.Forms.MessageBox]::Show("Please run PowerShell as Administrator!")
    break
}

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# --- GLOBAL FORM SETUP ---
$form = New-Object System.Windows.Forms.Form
$form.Text = "Ryan Standardization"
$form.Size = "450,550"
$form.StartPosition = "CenterScreen"
$form.BackColor = "White"
$form.Font = New-Object System.Drawing.Font("Segoe UI", 10)

# --- NAVIGATION LOGIC ---

# 1. Main Menu Function
function Show-Main-Menu {
    $form.Controls.Clear()
    
    $lbl = New-Object System.Windows.Forms.Label
    $lbl.Text = "Ryan Standardization"; $lbl.Font = New-Object System.Drawing.Font("Segoe UI", 14, [System.Drawing.FontStyle]::Bold)
    $lbl.Location = "0,40"; $lbl.Size = "450,40"; $lbl.TextAlign = "MiddleCenter"

    $btn1 = New-Object System.Windows.Forms.Button
    $btn1.Text = "1. Local Admin User Setup"; $btn1.Location = "75,110"; $btn1.Size = "300,50"; $btn1.FlatStyle = "Flat"
    $btn1.Add_Click({ Start-Process "lusrmgr.msc" })

    $btn2 = New-Object System.Windows.Forms.Button
    $btn2.Text = "2. GP Edit Setup"; $btn2.Location = "75,180"; $btn2.Size = "300,50"; $btn2.FlatStyle = "Flat"
    $btn2.Add_Click({ Show-GPO-Menu }) # Calls GPO Menu

    $btn3 = New-Object System.Windows.Forms.Button
    $btn3.Text = "3. Install Apps"; $btn3.Location = "75,250"; $btn3.Size = "300,50"; $btn3.FlatStyle = "Flat"
    $btn3.Add_Click({ 
        Write-Host "Installing Apps..." -ForegroundColor Yellow
        winget install --id Google.Chrome --silent --accept-package-agreements
        winget install --id VideoLAN.VLC --silent
        [System.Windows.Forms.MessageBox]::Show("Installation started.")
    })

    $form.Controls.AddRange(@($lbl, $btn1, $btn2, $btn3))
}

# 2. GPO Menu Function
function Show-GPO-Menu {
    $form.Controls.Clear()
    
    $btnBack = New-Object System.Windows.Forms.Button
    $btnBack.Text = "← Back"; $btnBack.Location = "15,15"; $btnBack.Size = "80,30"; $btnBack.FlatStyle = "Flat"
    $btnBack.Add_Click({ Show-Main-Menu }) # Goes back to Main

    $btnComp = New-Object System.Windows.Forms.Button
    $btnComp.Text = "Computer Configuration"; $btnComp.Location = "75,110"; $btnComp.Size = "300,50"; $btnComp.FlatStyle = "Flat"
    $btnComp.Add_Click({ Start-Process "secpol.msc" })

    $btnUser = New-Object System.Windows.Forms.Button
    $btnUser.Text = "User Configuration"; $btnUser.Location = "75,180"; $btnUser.Size = "300,50"; $btnUser.FlatStyle = "Flat"
    $btnUser.Add_Click({ Show-User-Config }) # Goes to User Config

    $form.Controls.AddRange(@($btnBack, $btnComp, $btnUser))
}

# 3. User Configuration Function
function Show-User-Config {
    $form.Controls.Clear()

    $btnBack = New-Object System.Windows.Forms.Button
    $btnBack.Text = "← Back"; $btnBack.Location = "15,15"; $btnBack.Size = "80,30"; $btnBack.FlatStyle = "Flat"
    $btnBack.Add_Click({ Show-GPO-Menu }) # Goes back to GPO Menu

    $panel = New-Object System.Windows.Forms.Panel
    $panel.Location = "50,70"; $panel.Size = "350,320"; $panel.AutoScroll = $true

    $opts = @("Remove Shutdown Button", "Hide Search", "Remove Notification Center", "Remove Pinned Apps", "Prevent Wallpaper Changes", "Disable USB Storage (User)", "Disable Microsoft Store (User)")
    $checks = @()
    $y = 10
    foreach ($text in $opts) {
        $c = New-Object System.Windows.Forms.CheckBox
        $c.Text = $text; $c.Location = "10,$y"; $c.Size = "280,30"
        $panel.Controls.Add($c)
        $checks += $c
        $y += 40
    }

    $btnConfirm = New-Object System.Windows.Forms.Button
    $btnConfirm.Text = "Confirm Changes"; $btnConfirm.Location = "125,420"; $btnConfirm.Size = "200,45"; $btnConfirm.BackColor = "LightGray"; $btnConfirm.FlatStyle = "Flat"
    $btnConfirm.Add_Click({
        # Policy logic goes here...
        gpupdate /force
        Stop-Process -Name explorer -Force
        [System.Windows.Forms.MessageBox]::Show("Applied!")
        Show-Main-Menu # Returns to start after applying
    })

    $form.Controls.AddRange(@($btnBack, $panel, $btnConfirm))
}

# --- START THE APP ---
Show-Main-Menu
$form.ShowDialog()
