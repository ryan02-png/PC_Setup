# Ensure secure connection
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# 1. Admin Check
if (-NOT ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    [System.Windows.Forms.MessageBox]::Show("Please run PowerShell as Administrator!")
    return
}

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# --- INITIALIZE THE WINDOW ---
$script:form = New-Object System.Windows.Forms.Form
$script:form.Text = "Ryan Standardization"
$script:form.Size = "450,550"
$script:form.StartPosition = "CenterScreen"
$script:form.BackColor = "White"
$script:form.Font = New-Object System.Drawing.Font("Segoe UI", 10)

# --- HELPER FUNCTION: INSTALLER WITH CONFIRMATION ---
function script:Install-App {
    param($appName, $wingetId)
    
    $result = [System.Windows.Forms.MessageBox]::Show("Install $appName?", "Confirmation", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Question)
    
    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
        Write-Host "Starting installation for $appName..." -ForegroundColor Cyan
        $cmd = "winget install --id $wingetId --silent --accept-package-agreements --accept-source-agreements"
        Invoke-Expression $cmd
        [System.Windows.Forms.MessageBox]::Show("$appName installation process finished.")
    }
}

# --- FUNCTION 1: MAIN MENU ---
function script:Show-Main-Menu {
    $script:form.Controls.Clear()
    
    $lbl = New-Object System.Windows.Forms.Label
    $lbl.Text = "Ryan Standardization"; $lbl.Font = New-Object System.Drawing.Font("Segoe UI", 14, [System.Drawing.FontStyle]::Bold)
    $lbl.Location = "0,30"; $lbl.Size = "450,40"; $lbl.TextAlign = "MiddleCenter"

    $btn1 = New-Object System.Windows.Forms.Button
    $btn1.Text = "1. Local Admin User Setup"; $btn1.Location = "75,90"; $btn1.Size = "300,50"; $btn1.FlatStyle = "Flat"
    $btn1.Add_Click({ Start-Process "lusrmgr.msc" })

    $btn2 = New-Object System.Windows.Forms.Button
    $btn2.Text = "2. GP Edit Setup"; $btn2.Location = "75,160"; $btn2.Size = "300,50"; $btn2.FlatStyle = "Flat"
    $btn2.Add_Click({ script:Show-GPO-Menu })

    $btn3 = New-Object System.Windows.Forms.Button
    $btn3.Text = "3. Install Apps"; $btn3.Location = "75,230"; $btn3.Size = "300,50"; $btn3.FlatStyle = "Flat"
    $btn3.Add_Click({ script:Show-Install-Apps })

    $btn4 = New-Object System.Windows.Forms.Button
    $btn4.Text = "4. Control Panel"; $btn4.Location = "75,300"; $btn4.Size = "300,50"; $btn4.FlatStyle = "Flat"
    $btn4.Add_Click({ Start-Process "control" })
    
    $script:form.Controls.AddRange(@($lbl, $btn1, $btn2, $btn3, $btn4))
}

# --- FUNCTION 2: GPO MENU ---
function script:Show-GPO-Menu {
    $script:form.Controls.Clear()
    
    $btnBack = New-Object System.Windows.Forms.Button
    $btnBack.Text = "← Back"; $btnBack.Location = "15,15"; $btnBack.Size = "80,30"; $btnBack.FlatStyle = "Flat"
    $btnBack.Add_Click({ script:Show-Main-Menu }) 

    $btnComp = New-Object System.Windows.Forms.Button
    $btnComp.Text = "Computer Configuration"; $btnComp.Location = "75,110"; $btnComp.Size = "300,50"; $btnComp.FlatStyle = "Flat"
    $btnComp.Add_Click({ Start-Process "secpol.msc" })

    $btnUser = New-Object System.Windows.Forms.Button
    $btnUser.Text = "User Configuration"; $btnUser.Location = "75,180"; $btnUser.Size = "300,50"; $btnUser.FlatStyle = "Flat"
    $btnUser.Add_Click({ script:Show-User-Config }) 

    $script:form.Controls.AddRange(@($btnBack, $btnComp, $btnUser))
