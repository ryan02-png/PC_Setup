# --- FUNCTION 3: USER CONFIGURATION (BLANK) ---
function script:Show-User-Config {
    $script:form.Controls.Clear()
    
    $btnBack = New-Object System.Windows.Forms.Button
    $btnBack.Text = "← Back"; $btnBack.Location = "15,15"; $btnBack.Size = "80,30"; $btnBack.FlatStyle = "Flat"
    $btnBack.Add_Click({ script:Show-GPO-Menu }) 
    
    $script:form.Controls.AddRange(@($btnBack))
}

# --- FUNCTION 4: INSTALL APPS MENU ---
function script:Show-Install-Apps {
    $script:form.Controls.Clear()
    
    $btnBack = New-Object System.Windows.Forms.Button
    $btnBack.Text = "← Back"; $btnBack.Location = "15,15"; $btnBack.Size = "80,30"; $btnBack.FlatStyle = "Flat"
    $btnBack.Add_Click({ script:Show-Main-Menu }) 

    $btnChrome = New-Object System.Windows.Forms.Button
    $btnChrome.Text = "Install Chrome"; $btnChrome.Location = "75,90"; $btnChrome.Size = "300,50"; $btnChrome.FlatStyle = "Flat"
    $btnChrome.Add_Click({ script:Install-App "Chrome" "Google.Chrome" })

    $btnFirefox = New-Object System.Windows.Forms.Button
    $btnFirefox.Text = "Install Firefox"; $btnFirefox.Location = "75,160"; $btnFirefox.Size = "300,50"; $btnFirefox.FlatStyle = "Flat"
    $btnFirefox.Add_Click({ script:Install-App "Firefox" "Mozilla.Firefox" })

    $btnAnyDesk = New-Object System.Windows.Forms.Button
    $btnAnyDesk.Text = "Install AnyDesk (5.4.2)"; $btnAnyDesk.Location = "75,230"; $btnAnyDesk.Size = "300,50"; $btnAnyDesk.FlatStyle = "Flat"
    $btnAnyDesk.Add_Click({ 
        $result = [System.Windows.Forms.MessageBox]::Show("Install AnyDesk (5.4.2)?", "Confirmation", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Question)
        
        if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
            Write-Host "Downloading AnyDesk 5.4.2 from GitHub..." -ForegroundColor Cyan
            
            # Using your exact link
            $directUrl = "https://github.com/ryan02-png/PC_Setup/raw/refs/heads/main/anydesk-5-4-2.exe" 
            $tempExe = "$env:TEMP\AnyDesk542.exe"
            
            try {
                Invoke-WebRequest -Uri $directUrl -OutFile $tempExe -UseBasicParsing
                
                if ((Get-Item $tempExe).Length -lt 1MB) {
                    [System.Windows.Forms.MessageBox]::Show("Download failed: File is too small to be AnyDesk. Check the link.")
                    return
                }

                Write-Host "Installing AnyDesk silently..." -ForegroundColor Cyan
                
                $installArgs = @("--install", "C:\Program Files (x86)\AnyDesk", "--start-with-win", "--create-shortcuts", "--create-desktop-icon", "--silent")
                Start-Process -FilePath $tempExe -ArgumentList $installArgs -Wait -NoNewWindow
                
                Remove-Item -Path $tempExe -Force
                [System.Windows.Forms.MessageBox]::Show("AnyDesk 5.4.2 installation finished. Check your desktop!")
            } catch {
                [System.Windows.Forms.MessageBox]::Show("Error downloading or installing AnyDesk.")
            }
        }
    })

    $btnMicroSIP = New-Object System.Windows.Forms.Button
    $btnMicroSIP.Text = "Install MicroSIP"; $btnMicroSIP.Location = "75,300"; $btnMicroSIP.Size = "300,50"; $btnMicroSIP.FlatStyle = "Flat"
    $btnMicroSIP.Add_Click({ script:Install-App "MicroSIP" "MicroSIP.MicroSIP" })

    $script:form.Controls.AddRange(@($btnBack, $btnChrome, $btnFirefox, $btnAnyDesk, $btnMicroSIP))
}

# --- START ---
script:Show-Main-Menu
$script:form.ShowDialog()
