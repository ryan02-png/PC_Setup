# --- FUNCTION 7: DESKTOP LAYOUT MENU ---
function script:Show-Desktop-Layout {
    $script:form.Controls.Clear()
    $btnBack = script:Create-BackButton { script:Show-Main-Menu }

    $btn1 = script:Create-MenuButton "🖼️ SPM Standardize Layout" 110 { 
        if ([System.Windows.Forms.MessageBox]::Show("This will wipe the desktop and build the corporate standard. Proceed?", "Standardize Layout", 1, 48) -eq 1) {
            
            Write-Host "Hiding Recycle Bin..." -ForegroundColor Yellow
            $rbPath1 = "$script:activeHKCU\Software\Microsoft\Windows\CurrentVersion\Explorer\HideDesktopIcons\NewStartPanel"
            $rbPath2 = "$script:activeHKCU\Software\Microsoft\Windows\CurrentVersion\Explorer\HideDesktopIcons\ClassicStartMenu"
            if (-not (Test-Path $rbPath1)) { New-Item -Path $rbPath1 -Force | Out-Null }
            if (-not (Test-Path $rbPath2)) { New-Item -Path $rbPath2 -Force | Out-Null }
            Set-ItemProperty -Path $rbPath1 -Name "{645FF040-5081-101B-9F08-00AA002F954E}" -Value 1 -Type DWord
            Set-ItemProperty -Path $rbPath2 -Name "{645FF040-5081-101B-9F08-00AA002F954E}" -Value 1 -Type DWord

            Write-Host "Configuring Taskbar (Hiding Bloat)..." -ForegroundColor Yellow
            Set-ItemProperty -Path "$script:activeHKCU\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" -Name "TaskbarAl" -Value 0 -Type DWord -ErrorAction SilentlyContinue
            Set-ItemProperty -Path "$script:activeHKCU\Software\Microsoft\Windows\CurrentVersion\Search" -Name "SearchboxTaskbarMode" -Value 0 -Type DWord -ErrorAction SilentlyContinue
            
            Set-ItemProperty -Path "$script:activeHKCU\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" -Name "ShowTaskViewButton" -Value 0 -Type DWord -ErrorAction SilentlyContinue
            
            $widgetPolicy = "HKLM:\SOFTWARE\Policies\Microsoft\Dsh"
            if (-not (Test-Path $widgetPolicy)) { New-Item -Path $widgetPolicy -Force | Out-Null }
            Set-ItemProperty -Path $widgetPolicy -Name "AllowNewsAndInterests" -Value 0 -Type DWord -ErrorAction SilentlyContinue

            $feedsPolicy = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Feeds"
            if (-not (Test-Path $feedsPolicy)) { New-Item -Path $feedsPolicy -Force | Out-Null }
            Set-ItemProperty -Path $feedsPolicy -Name "EnableFeeds" -Value 0 -Type DWord -ErrorAction SilentlyContinue
            
            Set-ItemProperty -Path "$script:activeHKCU\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" -Name "TaskbarMn" -Value 0 -Type DWord -ErrorAction SilentlyContinue
            $polExpPath = "$script:activeHKCU\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer"
            if (-not (Test-Path $polExpPath)) { New-Item -Path $polExpPath -Force | Out-Null }
            Set-ItemProperty -Path $polExpPath -Name "HideSCAMeetNow" -Value 1 -Type DWord -ErrorAction SilentlyContinue
            
            $polExplorerPath2 = "$script:activeHKCU\Software\Policies\Microsoft\Windows\Explorer"
            if (-not (Test-Path $polExplorerPath2)) { New-Item -Path $polExplorerPath2 -Force | Out-Null }
            Set-ItemProperty -Path $polExplorerPath2 -Name "DisableNotificationCenter" -Value 1 -Type DWord -ErrorAction SilentlyContinue

            Write-Host "Nuking Old Icons (Including OneDrive)..." -ForegroundColor Yellow
            
            $desktopPaths = @(
                "$env:PUBLIC\Desktop",
                "$script:activeProfile\Desktop",
                "$script:activeProfile\OneDrive\Desktop"
            )

            foreach ($dPath in $desktopPaths) {
                if (Test-Path $dPath) {
                    Remove-Item "$dPath\*" -Recurse -Force -ErrorAction SilentlyContinue
                }
            }
            Remove-Item "$script:activeLocalAppData\IconCache.db" -Force -ErrorAction SilentlyContinue 

            $WshShell = New-Object -ComObject WScript.Shell
            $targetDesktop = "$env:PUBLIC\Desktop"
            
            # Chrome
            $chromePath = "${env:ProgramFiles}\Google\Chrome\Application\chrome.exe"
            if (-not (Test-Path $chromePath)) { $chromePath = "${env:ProgramFiles(x86)}\Google\Chrome\Application\chrome.exe" }
            
            if (Test-Path $chromePath) {
                $chrome = $WshShell.CreateShortcut("$targetDesktop\Chrome.lnk")
                $chrome.TargetPath = $chromePath
                $chrome.IconLocation = "$chromePath,0"
                $chrome.Save()
            }

            # Office Paths Finder
            $excelPath = ""
            $wordPath = ""
            $officePaths = @(
                "$env:ProgramFiles\Microsoft Office\root\Office16",
                "${env:ProgramFiles(x86)}\Microsoft Office\root\Office16"
            )

            foreach ($p in $officePaths) {
                if (Test-Path "$p\EXCEL.EXE") { $excelPath = "$p\EXCEL.EXE" }
                if (Test-Path "$p\WINWORD.EXE") { $wordPath = "$p\WINWORD.EXE" }
            }

            # Excel
            if ($excelPath) {
                $excel = $WshShell.CreateShortcut("$targetDesktop\Excel.lnk")
                $excel.TargetPath = $excelPath 
                $excel.IconLocation = "$excelPath,0"
                $excel.Save()
            }

            # Word
            if ($wordPath) {
                $word = $WshShell.CreateShortcut("$targetDesktop\Word.lnk")
                $word.TargetPath = $wordPath
                $word.IconLocation = "$wordPath,0"
                $word.Save()
            }

            Stop-Process -Name explorer -Force
            [System.Windows.Forms.MessageBox]::Show("SPM Corporate Layout Applied successfully.")
        }
    }

    $script:form.Controls.AddRange(@($btnBack, $btn1))
}

# --- START ---
script:Show-Main-Menu
$script:form.ShowDialog()
