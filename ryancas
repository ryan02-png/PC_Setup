# --- FUNCTION 4: INSTALL APPS (RESPONSIVE GRID) ---
function script:Show-Install-Apps {
    $script:form.Controls.Clear()
    
    $btnBack = New-Object System.Windows.Forms.Button
    $btnBack.Text = "← Back"; $btnBack.Location = "15,15"; $btnBack.Size = "80,30"; $btnBack.FlatStyle = "Flat"
    $btnBack.BackColor = $script:btnGray; $btnBack.FlatAppearance.BorderColor = $script:borderGray
    $btnBack.Add_Click({ script:Show-Main-Menu }) 

    # FlowLayoutPanel automatically handles responsive wrapping!
    $panel = New-Object System.Windows.Forms.FlowLayoutPanel
    $panel.Location = "15,60"
    $panel.Size = "400,480"
    $panel.Anchor = [System.Windows.Forms.AnchorStyles]::Top -bor [System.Windows.Forms.AnchorStyles]::Bottom -bor [System.Windows.Forms.AnchorStyles]::Left -bor [System.Windows.Forms.AnchorStyles]::Right
    $panel.AutoScroll = $true

    function Add-WidgetBtn ($emoji, $text, $action) {
        $b = New-Object System.Windows.Forms.Button
        $b.Size = "115,115"
        $b.Margin = New-Object System.Windows.Forms.Padding(6) # Spacing between tiles
        $b.FlatStyle = "Flat"
        $b.BackColor = $script:btnGray
        $b.ForeColor = $script:textWhite
        $b.FlatAppearance.BorderColor = $script:borderGray
        
        $b.Text = "$emoji`n`n$text"
        $b.TextAlign = "MiddleCenter"
        $b.Add_Click($action)
        $panel.Controls.Add($b)
    }

    # WINGET APPS
    Add-WidgetBtn "🌐" "Chrome" { script:Install-App "Chrome" "Google.Chrome" }
    Add-WidgetBtn "🦊" "Firefox" { script:Install-App "Firefox" "Mozilla.Firefox" }
    Add-WidgetBtn "🦁" "Brave" { script:Install-App "Brave Browser" "Brave.Brave" }
    Add-WidgetBtn "📞" "MicroSIP" { script:Install-App "MicroSIP" "MicroSIP.MicroSIP" }
    Add-WidgetBtn "🐦" "Lark" { script:Install-App "Lark" "LarkTechnologies.Lark" }
    Add-WidgetBtn "📊" "Office 365" { script:Install-App "Microsoft 365" "Microsoft.Office" }
    Add-WidgetBtn "💻" "VS Code" { script:Install-App "VS Code" "Microsoft.VisualStudioCode" }
    Add-WidgetBtn "📝" "LibreOffice" { script:Install-App "LibreOffice" "TheDocumentFoundation.LibreOffice" }
    Add-WidgetBtn "📄" "LightPDF" { script:Install-App "LightPDF" "LightPDF.LightPDF" }
    Add-WidgetBtn "🛡️" "Pritunl" { script:Install-App "Pritunl" "Pritunl.Pritunl" }
    Add-WidgetBtn "🖥️" "TightVNC" { script:Install-App "TightVNC" "TightVNC.TightVNC" }

    # CUSTOM GITHUB APPS
    Add-WidgetBtn "🖥️" "AnyDesk" { script:Install-CustomApp "AnyDesk" "anydesk-5-4-2.exe" $false @("--install", "C:\Program Files (x86)\AnyDesk", "--start-with-win", "--create-shortcuts", "--create-desktop-icon", "--silent") }
    Add-WidgetBtn "🗄️" "MySQL ODBC 64" { script:Install-CustomApp "MySQL ODBC 5.1 (64-bit)" "mysql-odbc-64.msi" $true @("/qn", "/norestart") }
    Add-WidgetBtn "🗄️" "MySQL ODBC 32" { script:Install-CustomApp "MySQL ODBC 5.1 (32-bit)" "mysql-odbc-32.msi" $true @("/qn", "/norestart") }
    Add-WidgetBtn "👁️" "eyeBeam" { script:Install-CustomApp "eyeBeam" "eyebeam.exe" $false @("/S") }

    $script:form.Controls.AddRange(@($btnBack, $panel))
}

# --- START ---
script:Show-Main-Menu
$script:form.ShowDialog()
