function script:Show-Computer-Config {
    $script:form.Controls.Clear()
    $btnBack = script:Create-BackButton { script:Show-GPO-Menu }

    $panel = New-Object System.Windows.Forms.FlowLayoutPanel
    $panel.Location = "15,60"; $panel.Size = "400,530"
    $panel.Anchor = [System.Windows.Forms.AnchorStyles]::Top -bor [System.Windows.Forms.AnchorStyles]::Bottom -bor [System.Windows.Forms.AnchorStyles]::Left -bor [System.Windows.Forms.AnchorStyles]::Right
    $panel.AutoScroll = $true

    function Add-ListBtn ($text, $action) {
        $b = New-Object System.Windows.Forms.Button
        $b.Size = "370,45"
        $b.Margin = New-Object System.Windows.Forms.Padding(0, 0, 0, 10)
        $b.FlatStyle = "Flat"; $b.FlatAppearance.BorderSize = 0
        $b.BackColor = $script:btnGray; $b.ForeColor = $script:textWhite
        $b.Text = $text
        $b.Add_Click($action)
        $b.Region = script:Get-RoundedRegion $b.Width $b.Height 15
        $panel.Controls.Add($b)
    }

    Add-ListBtn "⏱️ Set Boot Timeout to 3 Secs" {
        Invoke-Expression "bcdedit /timeout 3"
        [System.Windows.Forms.MessageBox]::Show("Boot setup timeout set to 3 seconds.")
    }

    Add-ListBtn "🖨️ Turn Off File & Printer Sharing" {
        Set-NetFirewallRule -DisplayGroup "File and Printer Sharing" -Enabled False -ErrorAction SilentlyContinue
        [System.Windows.Forms.MessageBox]::Show("File and Printer Sharing has been disabled in the Windows Firewall.")
    }

    Add-ListBtn "🔒 Remove Lock Screen Power Button" {
        $regPath = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System"
        if (-not (Test-Path $regPath)) { New-Item -Path $regPath -Force | Out-Null }
        Set-ItemProperty -Path $regPath -Name "shutdownwithoutlogon" -Value 0 -Type DWord
        [System.Windows.Forms.MessageBox]::Show("Power button removed from the lock screen.")
    }

    Add-ListBtn "✅ Add Lock Screen Power Button" {
        $regPath = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System"
        if (-not (Test-Path $regPath)) { New-Item -Path $regPath -Force | Out-Null }
        Set-ItemProperty -Path $regPath -Name "shutdownwithoutlogon" -Value 1 -Type DWord
        [System.Windows.Forms.MessageBox]::Show("Power button added back to the lock screen.")
    }

    Add-ListBtn "🚫 Disable Microsoft Store (System-Wide)" { 
        $edition = (Get-ItemProperty "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion").EditionID
        if ($edition -match "Enterprise" -or $edition -match "Education") {
            $regPath = "HKLM:\SOFTWARE\Policies\Microsoft\WindowsStore"
            if (-not (Test-Path $regPath)) { New-Item -Path $regPath -Force | Out-Null }
            Set-ItemProperty -Path $regPath -Name "RemoveWindowsStore" -Value 1 -Type DWord
            Stop-Process -Name explorer -Force
            [System.Windows.Forms.MessageBox]::Show("Enterprise Edition detected. Store disabled via Machine Registry.")
        } else {
            $storeApp = Get-AppxPackage -AllUsers *WindowsStore* | Select-Object -First 1
            if ($storeApp) {
                $storePath = "$($storeApp.InstallLocation)\WinStore.App.exe"
                New-NetFirewallRule -DisplayName "Block_MS_Store" -Direction Outbound -Program $storePath -Action Block -ErrorAction SilentlyContinue
                [System.Windows.Forms.MessageBox]::Show("Pro/Home Edition detected. Store blocked via System Firewall (No Internet Connection).")
            } else {
                [System.Windows.Forms.MessageBox]::Show("MS Store executable not found.")
            }
        }
    }

    Add-ListBtn "✅ Enable Microsoft Store (System-Wide)" { 
        $regPath = "HKLM:\SOFTWARE\Policies\Microsoft\WindowsStore"
        if (Test-Path $regPath) { Remove-ItemProperty -Path $regPath -Name "RemoveWindowsStore" -ErrorAction SilentlyContinue }
        Remove-NetFirewallRule -DisplayName "Block_MS_Store" -ErrorAction SilentlyContinue
        Stop-Process -Name explorer -Force
        [System.Windows.Forms.MessageBox]::Show("Microsoft Store Enabled.")
    }

    Add-ListBtn "🚫 Disable PrintScreen Key" {
        $msg = "In order to take effect, the computer needs to restart.`n`nDisable PrintScreen and restart now?"
        if ([System.Windows.Forms.MessageBox]::Show($msg, "Restart Required", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Warning) -eq [System.Windows.Forms.DialogResult]::OK) {
            $regPath = "HKLM:\SYSTEM\CurrentControlSet\Control\Keyboard Layout"
            $hex = [byte[]](0x00,0x00,0x00,0x00, 0x00,0x00,0x00,0x00, 0x02,0x00,0x00,0x00, 0x00,0x00,0x37,0xE0, 0x00,0x00,0x00,0x00)
            Set-ItemProperty -Path $regPath -Name "Scancode Map" -Value $hex -Force
            Restart-Computer -Force
        }
    }

    Add-ListBtn "✅ Enable PrintScreen Key" {
        $msg = "In order to take effect, the computer needs to restart.`n`nEnable PrintScreen and restart now?"
        if ([System.Windows.Forms.MessageBox]::Show($msg, "Restart Required", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Warning) -eq [System.Windows.Forms.DialogResult]::OK) {
            $regPath = "HKLM:\SYSTEM\CurrentControlSet\Control\Keyboard Layout"
            Remove-ItemProperty -Path $regPath -Name "Scancode Map" -ErrorAction SilentlyContinue
            Restart-Computer -Force
        }
    }

    Add-ListBtn "🚫 Disable Bluetooth" {
        Stop-Service -Name bthserv -Force -ErrorAction SilentlyContinue
        Set-Service -Name bthserv -StartupType Disabled -ErrorAction SilentlyContinue
        [System.Windows.Forms.MessageBox]::Show("Bluetooth Support Service has been disabled system-wide.")
    }

    Add-ListBtn "✅ Enable Bluetooth" {
        Set-Service -Name bthserv -StartupType Manual -ErrorAction SilentlyContinue
        Start-Service -Name bthserv -ErrorAction SilentlyContinue
        [System.Windows.Forms.MessageBox]::Show("Bluetooth Support Service has been enabled.")
    }

    $script:form.Controls.AddRange(@($btnBack, $panel))
}

