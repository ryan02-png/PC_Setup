# --- FUNCTION 4: USER CONFIGURATION MENU ---
function script:Show-User-Config {
    $script:form.Controls.Clear()
    $btnBack = script:Create-BackButton { script:Show-GPO-Menu }

    $btn1 = script:Create-MenuButton "🚫 Disable USB Access" 80 { 
        $regPath = "HKCU:\Software\Policies\Microsoft\Windows\RemovableStorageDevices"
        if (-not (Test-Path $regPath)) { New-Item -Path $regPath -Force | Out-Null }
        Set-ItemProperty -Path $regPath -Name "Deny_All" -Value 1 -Type DWord
        Stop-Process -Name explorer -Force
        [System.Windows.Forms.MessageBox]::Show("USB Access Disabled for Current User.")
    }

    $btn2 = script:Create-MenuButton "✅ Enable USB Access" 140 { 
        $regPath = "HKCU:\Software\Policies\Microsoft\Windows\RemovableStorageDevices"
        if (Test-Path $regPath) { Remove-ItemProperty -Path $regPath -Name "Deny_All" -ErrorAction SilentlyContinue }
        Stop-Process -Name explorer -Force
        [System.Windows.Forms.MessageBox]::Show("USB Access Enabled for Current User.")
    }

    $btn3 = script:Create-MenuButton "🚫 Disable Microsoft Store" 200 { 
        $edition = (Get-ItemProperty "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion").EditionID
        if ($edition -match "Enterprise" -or $edition -match "Education") {
            $regPath = "HKCU:\Software\Policies\Microsoft\WindowsStore"
            if (-not (Test-Path $regPath)) { New-Item -Path $regPath -Force | Out-Null }
            Set-ItemProperty -Path $regPath -Name "RemoveWindowsStore" -Value 1 -Type DWord
            Stop-Process -Name explorer -Force
            [System.Windows.Forms.MessageBox]::Show("Enterprise Edition detected. Store disabled via Registry.")
        } else {
            $storeApp = Get-AppxPackage -AllUsers *WindowsStore* | Select-Object -First 1
            if ($storeApp) {
                $storePath = "$($storeApp.InstallLocation)\WinStore.App.exe"
                New-NetFirewallRule -DisplayName "Block_MS_Store" -Direction Outbound -Program $storePath -Action Block -ErrorAction SilentlyContinue
                [System.Windows.Forms.MessageBox]::Show("Pro/Home Edition detected. Store blocked via Firewall (No Internet Connection).")
            } else {
                [System.Windows.Forms.MessageBox]::Show("MS Store executable not found.")
            }
        }
    }

    $btn4 = script:Create-MenuButton "✅ Enable Microsoft Store" 260 { 
        $regPath = "HKCU:\Software\Policies\Microsoft\WindowsStore"
        if (Test-Path $regPath) { Remove-ItemProperty -Path $regPath -Name "RemoveWindowsStore" -ErrorAction SilentlyContinue }
        Remove-NetFirewallRule -DisplayName "Block_MS_Store" -ErrorAction SilentlyContinue
        Stop-Process -Name explorer -Force
        [System.Windows.Forms.MessageBox]::Show("Microsoft Store Enabled.")
    }

    $btn5 = script:Create-MenuButton "🗑️ Uninstall Built-in Apps" 320 { 
        if ([System.Windows.Forms.MessageBox]::Show("Remove Snipping Tool, Solitaire, and Outlook for this user?", "Uninstall Apps", 1, 48) -eq 1) {
            Write-Host "Stopping background processes..." -ForegroundColor Yellow
            Get-Process -Name SnippingTool, ScreenClippingHost, olk, MicrosoftSolitaireCollection -ErrorAction SilentlyContinue | Stop-Process -Force
            
            Write-Host "Uninstalling Apps (Current User)..." -ForegroundColor Yellow
            $apps = @("*ScreenSketch*", "*SolitaireCollection*", "*OutlookForWindows*")
            foreach ($app in $apps) {
                Get-AppxPackage -Name $app | Remove-AppxPackage -ErrorAction SilentlyContinue
            }
            [System.Windows.Forms.MessageBox]::Show("Snipping Tool, Solitaire, and Outlook completely removed for this user.")
        }
    }

    $script:form.Controls.AddRange(@($btnBack, $btn1, $btn2, $btn3, $btn4, $btn5))
}

# --- FUNCTION 5: SYSTEM CLEANUP MENU ---
function script:Show-System-Cleanup {
    $script:form.Controls.Clear()
    $btnBack = script:Create-BackButton { script:Show-Main-Menu }

    $btnBrowser = script:Create-MenuButton "🌐 Browser Cleanup (Cache & History)" 110 { 
        if ([System.Windows.Forms.MessageBox]::Show("Force close browsers and wipe Cache & History?", "Browser Cleanup", 1, 48) -eq 1) {
            Write-Host "Cleaning up browsers..." -ForegroundColor Yellow
            $oldAction = $ErrorActionPreference; $ErrorActionPreference = 'SilentlyContinue'
            
            Get-Process -Name chrome, msedge, firefox, brave -ErrorAction SilentlyContinue | Stop-Process -Force
            Start-Sleep -Seconds 2
            
            $paths = @(
                "$env:LOCALAPPDATA\Google\Chrome\User Data\*\Cache\Cache_Data\*",
                "$env:LOCALAPPDATA\Google\Chrome\User Data\*\History*",
                "$env:LOCALAPPDATA\Google\Chrome\User Data\*\Visited Links",
                "$env:LOCALAPPDATA\Microsoft\Edge\User Data\*\Cache\Cache_Data\*",
                "$env:LOCALAPPDATA\Microsoft\Edge\User Data\*\History*",
                "$env:LOCALAPPDATA\Microsoft\Edge\User Data\*\Visited Links",
                "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\*\Cache\Cache_Data\*",
                "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\*\History*",
                "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\*\Visited Links",
                "$env:LOCALAPPDATA\Mozilla\Firefox\Profiles\*\cache2\*"
            )
            foreach ($p in $paths) { Remove-Item -Path $p -Recurse -Force }
            
            $ErrorActionPreference = $oldAction
            [System.Windows.Forms.MessageBox]::Show("Browser Cache & History Cleanup complete!")
        }
    }

    $btnStorage = script:Create-MenuButton "💾 Storage Cleanup" 180 { 
        if ([System.Windows.Forms.MessageBox]::Show("Wipe Temp, Prefetch, Recycle Bin, Crash Dumps, and Update Cache?", "Storage Cleanup", 1, 48) -eq 1) {
            Write-Host "Cleaning up storage..." -ForegroundColor Yellow
            $oldAction = $ErrorActionPreference; $ErrorActionPreference = 'SilentlyContinue'
            
            Get-ChildItem -Path $env:TEMP, "$env:WINDIR\Temp", "$env:WINDIR\Prefetch" -Recurse -Force | Remove-Item -Recurse -Force
            Clear-RecycleBin -Force
            Get-ChildItem -Path "$env:ProgramData\Microsoft\Windows\WER\ReportArchive", "$env:ProgramData\Microsoft\Windows\WER\ReportQueue" -Recurse -Force | Remove-Item -Recurse -Force
            
            Stop-Service -Name wuauserv -Force
            Get-ChildItem -Path "$env:WINDIR\SoftwareDistribution\Download" -Recurse -Force | Remove-Item -Recurse -Force
            Start-Service -Name wuauserv
            
            $ErrorActionPreference = $oldAction
            [System.Windows.Forms.MessageBox]::Show("Storage Cleanup complete!")
        }
    }

    $btnCookies = script:Create-MenuButton "🍪 Wipe Browser Cookies" 250 {
        $warningMsg = "WARNING: Wiping cookies will forcefully log you out of all active website sessions (Office 365, emails, internal tools, etc.) and reset site preferences.`n`nAre you sure you want to proceed?"
        if ([System.Windows.Forms.MessageBox]::Show($warningMsg, "Wipe Cookies Warning", [System.Windows.Forms.MessageBoxButtons]::YesNo, [System.Windows.Forms.MessageBoxIcon]::Warning) -eq [System.Windows.Forms.DialogResult]::Yes) {
            Write-Host "Wiping browser cookies..." -ForegroundColor Yellow
            $oldAction = $ErrorActionPreference; $ErrorActionPreference = 'SilentlyContinue'
            
            Get-Process -Name chrome, msedge, firefox, brave -ErrorAction SilentlyContinue | Stop-Process -Force
            Start-Sleep -Seconds 2
            
            $cookiePaths = @(
                "$env:LOCALAPPDATA\Google\Chrome\User Data\*\Cookies",
                "$env:LOCALAPPDATA\Google\Chrome\User Data\*\Network\Cookies",
                "$env:LOCALAPPDATA\Microsoft\Edge\User Data\*\Cookies",
                "$env:LOCALAPPDATA\Microsoft\Edge\User Data\*\Network\Cookies",
                "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\*\Cookies",
                "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\*\Network\Cookies",
                "$env:LOCALAPPDATA\Mozilla\Firefox\Profiles\*\cookies.sqlite"
            )
            foreach ($p in $cookiePaths) { Remove-Item -Path $p -Recurse -Force }
            
            $ErrorActionPreference = $oldAction
            [System.Windows.Forms.MessageBox]::Show("Browser Cookies have been wiped. You will need to log back into your websites.")
        }
    }

    $script:form.Controls.AddRange(@($btnBack, $btnBrowser, $btnStorage, $btnCookies))
}

