    $btn1 = script:Create-MenuButton "🖼️ SPM Standardize Layout" 110 { 
        if ([System.Windows.Forms.MessageBox]::Show("This will clear the desktop, arrange icons, hide the recycle bin, and align the taskbar. Proceed?", "Standardize Layout", 1, 48) -eq 1) {
            
            Write-Host "Hiding Recycle Bin..." -ForegroundColor Yellow
            $rbPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\HideDesktopIcons\NewStartPanel"
            if (-not (Test-Path $rbPath)) { New-Item -Path $rbPath -Force | Out-Null }
            Set-ItemProperty -Path $rbPath -Name "{645FF040-5081-101B-9F08-00AA002F954E}" -Value 1 -Type DWord

            Write-Host "Configuring Taskbar..." -ForegroundColor Yellow
            # Align Taskbar to Left (Win 11)
            Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" -Name "TaskbarAl" -Value 0 -Type DWord -ErrorAction SilentlyContinue
            # Hide Search Bar (Win 11)
            Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Search" -Name "SearchboxTaskbarMode" -Value 0 -Type DWord -ErrorAction SilentlyContinue

            Write-Host "Clearing and Rebuilding Desktop Icons..." -ForegroundColor Yellow
            # Delete everything from Public and User desktop
            Remove-Item "$env:PUBLIC\Desktop\*" -Recurse -Force -ErrorAction SilentlyContinue
            Remove-Item "$env:USERPROFILE\Desktop\*" -Recurse -Force -ErrorAction SilentlyContinue

            # Create specific shortcuts sequentially so they stack
            $WshShell = New-Object -ComObject WScript.Shell
            
            # Chrome
            $chrome = $WshShell.CreateShortcut("$env:USERPROFILE\Desktop\1 - Chrome.lnk")
            $chrome.TargetPath = "C:\Program Files\Google\Chrome\Application\chrome.exe"
            $chrome.Save()

            # Excel
            $excel = $WshShell.CreateShortcut("$env:USERPROFILE\Desktop\2 - Excel.lnk")
            $excel.TargetPath = "C:\Program Files\Microsoft Office\root\Office16\EXCEL.EXE" 
            $excel.Save()

            # Word
            $word = $WshShell.CreateShortcut("$env:USERPROFILE\Desktop\3 - Word.lnk")
            $word.TargetPath = "C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE"
            $word.Save()

            # Restart Explorer to apply icon, bin, and taskbar changes
            Stop-Process -Name explorer -Force
            [System.Windows.Forms.MessageBox]::Show("SPM Corporate Layout Applied successfully.")
        }
    }

    $script:form.Controls.AddRange(@($btnBack, $btn1))
}

# --- START ---
script:Show-Main-Menu
$script:form.ShowDialog()
