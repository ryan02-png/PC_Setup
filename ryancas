# Ensure secure connection to GitHub
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# 1. Admin Check
if (-NOT ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    [System.Windows.Forms.MessageBox]::Show("Please run PowerShell as Administrator!")
    break
}

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# --- UI SETUP ---
$form = New-Object System.Windows.Forms.Form
$form.Text = "Ryan Standardization"
$form.Size = New-Object System.Drawing.Size(400,280)
$form.StartPosition = "CenterScreen"
$form.BackColor = "White"

# --- 1. LOCAL ADMIN USER SETUP ---
$btnUser = New-Object System.Windows.Forms.Button
$btnUser.Location = New-Object System.Drawing.Point(50,30)
$btnUser.Size = New-Object System.Drawing.Size(300,45)
$btnUser.Text = "1. Local Admin User Setup"
$btnUser.Cursor = [System.Windows.Forms.Cursors]::Hand
$btnUser.Add_Click({
    Write-Host "Opening Local Users and Groups..." -ForegroundColor Cyan
    # Redirects directly to the Windows User Management Console
    Start-Process "lusrmgr.msc"
})

# --- 2. GP EDIT SETUP ---
$btnGPO = New-Object System.Windows.Forms.Button
$btnGPO.Location = New-Object System.Drawing.Point(50,90)
$btnGPO.Size = New-Object System.Drawing.Size(300,45)
$btnGPO.Text = "2. GP Edit Setup"
$btnGPO.Cursor = [System.Windows.Forms.Cursors]::Hand
$btnGPO.Add_Click({
    Write-Host "Forcing Group Policy Update..." -ForegroundColor Cyan
    gpupdate /force
    Write-Host "Opening Group Policy Editor..." -ForegroundColor Green
    Start-Process "gpedit.msc"
})

# --- 3. INSTALL APPS ---
$btnApps = New-Object System.Windows.Forms.Button
$btnApps.Location = New-Object System.Drawing.Point(50,150)
$btnApps.Size = New-Object System.Drawing.Size(300,45)
$btnApps.Text = "3. Install Apps"
$btnApps.Cursor = [System.Windows.Forms.Cursors]::Hand
$btnApps.Add_Click({
    Write-Host "Installing standard applications..." -ForegroundColor Yellow
    winget install --id Google.Chrome --silent --accept-package-agreements
    winget install --id VideoLAN.VLC --silent
    winget install --id 7zip.7zip --silent
    [System.Windows.Forms.MessageBox]::Show("Installation started for Chrome, VLC, and 7-Zip.")
})

# Add controls to form
$form.Controls.AddRange(@($btnUser, $btnGPO, $btnApps))
$form.ShowDialog()
