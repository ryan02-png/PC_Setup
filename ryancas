# Ensure secure connection to GitHub
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# 1. Admin Check
if (-NOT ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    [System.Windows.Forms.MessageBox]::Show("Please run PowerShell as Administrator!")
    break
}

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# --- MAIN FORM ---
$mainForm = New-Object System.Windows.Forms.Form
$mainForm.Text = "Ryan Standardization"
$mainForm.Size = "400,280"; $mainForm.StartPosition = "CenterScreen"

$btnUser = New-Object System.Windows.Forms.Button
$btnUser.Location = "50,30"; $btnUser.Size = "300,45"; $btnUser.Text = "1. Local Admin User Setup"
$btnUser.Add_Click({ Start-Process "lusrmgr.msc" })

$btnGPO = New-Object System.Windows.Forms.Button
$btnGPO.Location = "50,90"; $btnGPO.Size = "300,45"; $btnGPO.Text = "2. GP Edit Setup"
$btnGPO.Add_Click({ Show-GPO-Menu })

$btnApps = New-Object System.Windows.Forms.Button
$btnApps.Location = "50,150"; $btnApps.Size = "300,45"; $btnApps.Text = "3. Install Apps"
$btnApps.Add_Click({ 
    winget install --id Google.Chrome --silent --accept-package-agreements
    winget install --id VideoLAN.VLC --silent
    [System.Windows.Forms.MessageBox]::Show("Apps installation started.")
})

# --- SUB-MENU: GP EDIT SETUP ---
function Show-GPO-Menu {
    $gpoForm = New-Object System.Windows.Forms.Form
    $gpoForm.Text = "GP Edit Setup"; $gpoForm.Size = "400,250"; $gpoForm.StartPosition = "CenterParent"
    
    $btnComp = New-Object System.Windows.Forms.Button
    $btnComp.Text = "Computer Configuration"; $btnComp.Location = "50,40"; $btnComp.Size = "300,40"
    $btnComp.Add_Click({ Start-Process "secpol.msc" })

    $btnUserConfig = New-Object System.Windows.Forms.Button
    $btnUserConfig.Text = "User Configuration"; $btnUserConfig.Location = "50,100"; $btnUserConfig.Size = "300,40"
    $btnUserConfig.Add_Click({ Show-User-Config })

    $gpoForm.Controls.AddRange(@($btnComp, $btnUserConfig))
    $gpoForm.ShowDialog()
}

# --- SUB-MENU: USER CONFIGURATION ---
function Show-User-Config {
    $ucForm = New-Object System.Windows.Forms.Form
    $ucForm.Text = "User Configuration"; $ucForm.Size = "450,550"; $ucForm.StartPosition = "CenterParent"

    $chkShutdown = New-Object System.Windows.Forms.CheckBox; $chkShutdown.Text = "Remove Shutdown Button"; $chkShutdown.Location = "30,30"; $chkShutdown.Width = 300
    $chkSearch = New-Object System.Windows.Forms.CheckBox; $chkSearch.Text = "Hide Search"; $chkSearch.Location = "30,60"
    $chkNotif = New-Object System.Windows.Forms.CheckBox; $chkNotif.Text = "Remove Notification Center"; $chkNotif.Location = "30,90"
    $chkPinned = New-Object System.Windows.Forms.CheckBox; $chkPinned.Text = "Remove Pinned Apps"; $chkPinned.Location = "30,120"
    $chkWall = New-Object System.Windows.Forms.CheckBox; $chkWall.Text = "Prevent Wallpaper Changes"; $chkWall.Location = "30,150"
    $chkUSB = New-Object System.Windows.Forms.CheckBox; $chkUSB.Text = "Disable USB Storage"; $chkUSB.Location = "30,180"
    $chkStore = New-Object System.Windows.Forms.CheckBox; $chkStore.Text = "Disable Microsoft Store"; $chkStore.Location = "30,210"
    $chkWinSearch = New-Object System.Windows.Forms.CheckBox; $chkWinSearch.Text = "Disable Windows Search"; $chkWinSearch.Location = "30,240"

    $btnConfirm = New-Object System.Windows.Forms.Button
    $btnConfirm.Text = "Confirm"; $btnConfirm.Location = "300,450"; $btnConfirm.Size = "100,40"
    
    $btnConfirm.Add_Click({
        # --- GPO REGISTRY PATHS ---
        $polExplorer = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer"
        $polSystem = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Policies\System"
        $polStore = "HKLM:\SOFTWARE\Policies\Microsoft\WindowsStore"

        if (!(Test-Path $polExplorer)) { New-Item $polExplorer -Force }
        if (!(Test-Path $polSystem)) { New-Item $polSystem -Force }
        if (!(Test-Path $polStore)) { New-Item $polStore -Force }

        # 1. Shutdown Button
        if ($chkShutdown.Checked) { Set-ItemProperty $polExplorer -Name "NoClose" -Value 1 -Type DWord }
        # 2. Hide Search (Taskbar)
        if ($chkSearch.Checked) { Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Search" -Name "SearchboxTaskbarMode" -Value 0 -Type DWord }
        # 3. Notification Center
        if ($chkNotif.Checked) { Set-ItemProperty $polExplorer -Name "DisableNotificationCenter" -Value 1 -Type DWord }
        # 4. Pinned Apps (Hide Taskbar buttons)
        if ($chkPinned.Checked) { Set-ItemProperty $polExplorer -Name "NoTaskGrouping" -Value 1 -Type DWord }
        # 5. Prevent Wallpaper Changes
        if ($chkWall.Checked) { Set-ItemProperty $polActiveDesktop -Name "NoChangingWallPaper" -Value 1 -Type DWord }
        # 6. Disable USB Storage (System Level)
        if ($chkUSB.Checked) { Set-ItemProperty "HKLM:\SYSTEM\CurrentControlSet\Services\USBSTOR" -Name "Start" -Value 4 -Type DWord }
        # 7. Disable Microsoft Store (GPO Method)
        if ($chkStore.Checked) { Set-ItemProperty $polStore -Name "RemoveWindowsStore" -Value 1 -Type DWord }
        # 8. Disable Search Service
        if ($chkWinSearch.Checked) { Stop-Service WSearch -ErrorAction SilentlyContinue; Set-Service WSearch -StartupType Disabled }

        gpupdate /force
        # Restart explorer to refresh UI
        Stop-Process -Name explorer -Force
        [System.Windows.Forms.MessageBox]::Show("GPO Policies applied! Windows Explorer has been restarted.")
        $ucForm.Close()
    })

    $ucForm.Controls.AddRange(@($chkShutdown, $chkSearch, $chkNotif, $chkPinned, $chkWall, $chkUSB, $chkStore, $chkWinSearch, $btnConfirm))
    $ucForm.ShowDialog()
}

$mainForm.Controls.AddRange(@($btnUser, $btnGPO, $btnApps))
$mainForm.ShowDialog()
