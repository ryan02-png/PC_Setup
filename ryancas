# --- HELPER FUNCTION: ROUNDED CORNERS MATH ---
function script:Get-RoundedRegion {
    param($w, $h, $r)
    $path = New-Object System.Drawing.Drawing2D.GraphicsPath
    $d = $r * 2
    if ($w -lt $d -or $h -lt $d) { return $null }
    $path.AddArc(0, 0, $d, $d, 180, 90)
    $path.AddArc($w - $d, 0, $d, $d, 270, 90)
    $path.AddArc($w - $d, $h - $d, $d, $d, 0, 90)
    $path.AddArc(0, $h - $d, $d, $d, 90, 90)
    $path.CloseFigure()
    return New-Object System.Drawing.Region($path)
}

# --- HELPER FUNCTION: WINGET INSTALLER ---
function script:Install-App {
    param($appName, $wingetId, $silent=$true)
    $result = [System.Windows.Forms.MessageBox]::Show("Install $appName?", "Confirmation", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Question)
    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
        Write-Host "Starting installation for $appName..." -ForegroundColor Cyan
        $args = "--id $wingetId --accept-package-agreements --accept-source-agreements"
        if ($silent) { $args += " --silent" } else { $args += " --interactive" }
        Invoke-Expression "winget install $args"
        [System.Windows.Forms.MessageBox]::Show("$appName installation process finished.")
    }
}

# --- HELPER FUNCTION: CUSTOM INSTALLER ---
function script:Install-CustomApp {
    param($appName, $fullUrl, $fileName, $isMsi, $installArgs)
    $result = [System.Windows.Forms.MessageBox]::Show("Install $appName?", "Confirmation", [System.Windows.Forms.MessageBoxButtons]::OKCancel, [System.Windows.Forms.MessageBoxIcon]::Question)
    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
        Write-Host "Downloading $appName..." -ForegroundColor Cyan
        
        $tempFile = "$env:TEMP\$fileName"
        
        try {
            $webClient = New-Object System.Net.WebClient
            $webClient.Headers.Add("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64)")
            $webClient.DownloadFile($fullUrl, $tempFile)

            if ((Get-Item $tempFile).Length -lt 100KB) { 
                [System.Windows.Forms.MessageBox]::Show("Download failed. File is too small.")
                return 
            }
            
            Write-Host "Installing $appName..." -ForegroundColor Cyan
            
            # Safe logic check to prevent the ArgumentList error
            $hasArgs = ($null -ne $installArgs) -and ($installArgs.Count -gt 0)

            if ($isMsi) { 
                $msiArgs = @("/i", "`"$tempFile`"")
                if ($hasArgs) { $msiArgs += $installArgs }
                Start-Process -FilePath "msiexec.exe" -ArgumentList $msiArgs -Wait -NoNewWindow 
            } 
            else { 
                if ($hasArgs) {
                    Start-Process -FilePath $tempFile -ArgumentList $installArgs -Wait -NoNewWindow 
                } else {
                    Start-Process -FilePath $tempFile -Wait -NoNewWindow 
                }
            }
            
            Remove-Item -Path $tempFile -Force
            [System.Windows.Forms.MessageBox]::Show("$appName installation finished.")
        } catch { [System.Windows.Forms.MessageBox]::Show("Error downloading/installing $appName. Details: " + $_.Exception.Message) }
    }
}

# --- HELPER FUNCTION: MENU BUTTON STYLER ---
function script:Create-MenuButton ($text, $yPos, $action) {
    $btn = New-Object System.Windows.Forms.Button
    $btn.Text = $text; $btn.Location = "50,$yPos"; $btn.Size = "330,45"
    $btn.Anchor = [System.Windows.Forms.AnchorStyles]::Top -bor [System.Windows.Forms.AnchorStyles]::Left -bor [System.Windows.Forms.AnchorStyles]::Right
    $btn.FlatStyle = "Flat"
    $btn.FlatAppearance.BorderSize = 0 
    $btn.BackColor = $script:btnGray; $btn.ForeColor = $script:textWhite
    $btn.Add_Click($action)
    
    $btn.Region = script:Get-RoundedRegion $btn.Width $btn.Height 15
    $btn.Add_SizeChanged({ $this.Region = script:Get-RoundedRegion $this.Width $this.Height 15 })
    return $btn
}

# --- HELPER FUNCTION: BACK BUTTON STYLER ---
function script:Create-BackButton ($action) {
    $btnBack = New-Object System.Windows.Forms.Button
    $btnBack.Text = "← Back"; $btnBack.Location = "15,15"; $btnBack.Size = "80,30"
    $btnBack.FlatStyle = "Flat"; $btnBack.FlatAppearance.BorderSize = 0
    $btnBack.BackColor = $script:btnGray
    $btnBack.Add_Click($action)
    $btnBack.Region = script:Get-RoundedRegion $btnBack.Width $btnBack.Height 12
    return $btnBack
}

# --- FUNCTION 1: MAIN MENU ---
function script:Show-Main-Menu {
    $script:form.Controls.Clear()
    
    $lbl = New-Object System.Windows.Forms.Label
    $lbl.Text = "Ryan Standardization"; $lbl.Font = New-Object System.Drawing.Font("Segoe UI", 14, [System.Drawing.FontStyle]::Bold)
    $lbl.Location = "0,25"; $lbl.Size = "450,40"; $lbl.TextAlign = "MiddleCenter"
    $lbl.Anchor = [System.Windows.Forms.AnchorStyles]::Top -bor [System.Windows.Forms.AnchorStyles]::Left -bor [System.Windows.Forms.AnchorStyles]::Right

    $btn1 = script:Create-MenuButton "👤 Local Admin User Setup" 80 { Start-Process "lusrmgr.msc" }
    $btn2 = script:Create-MenuButton "⚙️ GP Edit Setup" 140 { script:Show-GPO-Menu }
    $btn3 = script:Create-MenuButton "📦 Install Apps" 200 { script:Show-Install-Apps }
    $btn4 = script:Create-MenuButton "🎛️ Control Panel" 260 { Start-Process "control" }
    
    $btn5 = script:Create-MenuButton "🛠️ System Repair (SFC / DISM)" 320 { 
        if ([System.Windows.Forms.MessageBox]::Show("Repair Windows? (15 mins)", "System Repair", 1, 48) -eq 1) {
            Start-Process powershell.exe -ArgumentList "-NoExit -Command `"Write-Host 'Running DISM...' -F Cyan; DISM /Online /Cleanup-Image /RestoreHealth; Write-Host '`nRunning SFC...' -F Cyan; sfc /scannow`""
        }
    }

    $btn6 = script:Create-MenuButton "🧹 Storage & Browser Cleanup" 380 { 
        if ([System.Windows.Forms.MessageBox]::Show("Wipe Temp, Cache, and Windows Updates?", "Cleanup", 1, 48) -eq 1) {
            Write-Host "Cleaning up system..." -ForegroundColor Yellow
            $oldAction = $ErrorActionPreference; $ErrorActionPreference = 'SilentlyContinue'
            
            Get-Process -Name chrome, msedge, firefox, brave -ErrorAction SilentlyContinue | Stop-Process -Force
            Start-Sleep -Seconds 2
            
            Get-ChildItem -Path $env:TEMP, "$env:WINDIR\Temp", "$env:WINDIR\Prefetch" -Recurse -Force | Remove-Item -Recurse -Force
            
            Stop-Service -Name wuauserv -Force
            Get-ChildItem -Path "$env:WINDIR\SoftwareDistribution\Download" -Recurse -Force | Remove-Item -Recurse -Force
            Start-Service -Name wuauserv
            
            $paths = @(
                "$env:LOCALAPPDATA\Google\Chrome\User Data\*\Cache\Cache_Data\*",
                "$env:LOCALAPPDATA\Microsoft\Edge\User Data\*\Cache\Cache_Data\*",
                "$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data\*\Cache\Cache_Data\*",
                "$env:LOCALAPPDATA\Mozilla\Firefox\Profiles\*\cache2\*"
            )
            foreach ($p in $paths) { Remove-Item -Path $p -Recurse -Force }
            
            $ErrorActionPreference = $oldAction
            [System.Windows.Forms.MessageBox]::Show("Cleanup complete!")
        }
    }
    
    $script:form.Controls.AddRange(@($lbl, $btn1, $btn2, $btn3, $btn4, $btn5, $btn6))
}

